{
  "schemaVersion": 1,
  "id": "skiptransitions",
  "version": "${version}",
  "name": "Skip Transitions",
  "description": "Removes transitions when starting, changing resources, and more",
  "authors": [
    "JavaChef"
  ],
  "contact": {
    "homepage": "https://github.com/javachefmc/skip-transitions/",
    "issues": "https://github.com/javachefmc/skip-transitions/issues",
    "sources": "https://github.com/javachefmc/skip-transitions/"
  },
  "license": "GNU Lesser General Public License version 3 (LGPLv3)",
  "icon": "assets/skiptransitions/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.javachef.skiptransitions.SkipTransitions"
    ]
  },
  "mixins": [
    "skiptransitions.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ">=${minecraft_version}",
    "java": ">=21"
  }
}
